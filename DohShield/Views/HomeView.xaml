<UserControl x:Class="DohShield.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:engine="clr-namespace:DohShield.Engine"
             Background="{StaticResource SurfaceBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="20">

      <!-- 狀態卡片 -->
      <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- 狀態指示 -->
          <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Ellipse Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center">
              <Ellipse.Style>
                <Style TargetType="Ellipse">
                  <Setter Property="Fill" Value="#9E9E9E"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding EngineState}" Value="{x:Static engine:EngineState.Running}">
                      <Setter Property="Fill" Value="#4CAF50"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding EngineState}" Value="{x:Static engine:EngineState.Starting}">
                      <Setter Property="Fill" Value="#FF9800"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding EngineState}" Value="{x:Static engine:EngineState.Error}">
                      <Setter Property="Fill" Value="#F44336"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Ellipse.Style>
            </Ellipse>
            <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <!-- 連線時間 -->
          <TextBlock Grid.Row="1" Grid.Column="0"
                     Text="{Binding ConnectionDuration}" FontSize="28" FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}" Margin="0,4,0,4"/>

          <!-- 伺服器名稱 -->
          <TextBlock Grid.Row="2" Grid.Column="0"
                     Text="{Binding ServerDisplayName, StringFormat='伺服器：{0}'}"
                     FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>

          <!-- 開關按鈕 -->
          <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                      VerticalAlignment="Center" HorizontalAlignment="Right">
            <Button Content="啟動攔截" Command="{Binding StartCommand}"
                    Width="100" Margin="0,0,0,8">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsStopped}" Value="False">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
            <Button Content="停止攔截" Command="{Binding StopCommand}"
                    Width="100" Padding="16,8" BorderThickness="1"
                    BorderBrush="{StaticResource DangerBrush}" Foreground="{StaticResource DangerBrush}"
                    Background="White">
              <Button.Style>
                <Style TargetType="Button">
                  <Setter Property="Cursor" Value="Hand"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsRunning}" Value="False">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 錯誤訊息 -->
      <Border Background="#FFEBEE" CornerRadius="4" Padding="12,8" Margin="0,0,0,16"
              Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibilityConverter}}">
        <TextBlock Text="{Binding ErrorMessage}" Foreground="#C62828" FontSize="13" TextWrapping="Wrap"/>
      </Border>

      <!-- 統計卡片 -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="8"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 總查詢數 -->
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="總查詢數" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding TotalQueries}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- 快取命中 -->
        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="快取命中" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding CachedQueries}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>

        <!-- 平均回應 -->
        <Border Grid.Column="4" Style="{StaticResource CardStyle}">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="平均回應" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding AvgResponseMs, StringFormat='{}{0:F0} ms'}" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
          </StackPanel>
        </Border>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</UserControl>
