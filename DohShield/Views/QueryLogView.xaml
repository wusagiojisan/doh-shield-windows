<UserControl x:Class="DohShield.Views.QueryLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource SurfaceBrush}">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <!-- 搜尋列 -->
      <RowDefinition Height="Auto"/>
      <!-- DataGrid -->
      <RowDefinition Height="*"/>
      <!-- 底部工具列 -->
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 搜尋列 -->
    <Grid Grid.Row="0" Margin="0,0,0,12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
               Padding="8,4" FontSize="13"
               BorderBrush="#BDBDBD" BorderThickness="1"
               VerticalContentAlignment="Center">
        <TextBox.Style>
          <Style TargetType="TextBox">
            <Style.Resources>
              <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                <VisualBrush.Visual>
                  <TextBlock Text="搜尋網域..." Foreground="#9E9E9E" FontSize="13" Margin="8,0"/>
                </VisualBrush.Visual>
              </VisualBrush>
            </Style.Resources>
            <Style.Triggers>
              <Trigger Property="Text" Value="">
                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </TextBox.Style>
      </TextBox>

      <!-- Type 過濾 ComboBox -->
      <ComboBox Grid.Column="2" ItemsSource="{Binding TypeFilters}"
                SelectedItem="{Binding SelectedType}"
                Width="90" Padding="8,4" FontSize="13"
                VerticalContentAlignment="Center"/>
    </Grid>

    <!-- 查詢紀錄 DataGrid（最多 200 筆） -->
    <DataGrid Grid.Row="1"
              ItemsSource="{Binding DisplayLogs}"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              GridLinesVisibility="Horizontal"
              HorizontalGridLinesBrush="#E0E0E0"
              BorderBrush="#BDBDBD"
              BorderThickness="1"
              AlternatingRowBackground="#FAFAFA"
              HeadersVisibility="Column"
              SelectionMode="Single"
              FontSize="12">

      <DataGrid.Columns>
        <DataGridTextColumn Header="時間" Width="90"
                            Binding="{Binding LocalTime, StringFormat='HH:mm:ss'}"/>
        <DataGridTextColumn Header="網域" Width="*" Binding="{Binding Domain}"/>
        <DataGridTextColumn Header="類型" Width="55" Binding="{Binding TypeName}"/>
        <DataGridTemplateColumn Header="快取" Width="50">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock HorizontalAlignment="Center"
                         Text="{Binding Cached, Converter={StaticResource BoolToHitConverter}}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="回應(ms)" Width="75"
                            Binding="{Binding ResponseTimeMs}"/>
        <DataGridTextColumn Header="伺服器" Width="80"
                            Binding="{Binding ResolvedBy}"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- 底部工具列 -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
      <Button Content="重新整理" Command="{Binding RefreshCommand}"
              Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Width="90"/>
      <Button Content="清除紀錄" Command="{Binding ClearLogsCommand}"
              Padding="16,8" Background="White" BorderBrush="#9E9E9E" BorderThickness="1"
              Width="90"/>
    </StackPanel>
  </Grid>
</UserControl>
