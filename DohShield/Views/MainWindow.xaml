<Window x:Class="DohShield.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DohShield.Views"
        Title="DOH Shield"
        Width="520" Height="460"
        MinWidth="480" MinHeight="420"
        Background="{StaticResource SurfaceBrush}"
        WindowStartupLocation="CenterScreen">

  <Grid>
    <Grid.RowDefinitions>
      <!-- 標題列 -->
      <RowDefinition Height="Auto"/>
      <!-- Tab 內容 -->
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- 標題 -->
    <Border Grid.Row="0" Background="{StaticResource AccentBrush}" Padding="16,10">
      <TextBlock Text="DOH Shield" FontSize="18" FontWeight="Bold" Foreground="White"/>
    </Border>

    <!-- Tab 主體 -->
    <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">

      <TabItem Header="首頁" Padding="16,8">
        <views:HomeView x:Name="HomeViewControl"/>
      </TabItem>

      <TabItem Header="查詢紀錄" Padding="16,8">
        <views:QueryLogView x:Name="QueryLogViewControl"/>
      </TabItem>

      <TabItem Header="設定" Padding="16,8">
        <views:SettingsView x:Name="SettingsViewControl"/>
      </TabItem>

    </TabControl>
  </Grid>
</Window>
